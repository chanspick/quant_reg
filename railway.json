{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "scanner-api/Dockerfile",
    "watchPatterns": [
      "scanner/**",
      "scanner-api/**",
      "src/**",
      "public/**",
      "package.json",
      "pnpm-lock.yaml",
      ".npmrc",
      ".dockerignore",
      "vite.config.ts",
      "index.html",
      "railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
