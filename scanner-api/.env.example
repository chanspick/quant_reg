# SPEC-PQC-002 Phase A-3 — scanner-api 환경변수 예시
# 이 파일을 .env 로 복사한 뒤 값을 채워 사용 (uvicorn 은 자동 로드 안 함; docker-compose 또는 shell export 권장).

# uvicorn 바인딩 포트 (Railway 는 PORT 를 주입)
PORT=8000

# 로깅 레벨 — DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO

# CORS 화이트리스트 (콤마 구분, scheme 필수). 미설정 시 localhost:5173,5174 만 허용.
# production 예시: ALLOWED_ORIGINS=https://quant-reg.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# scanner/ 패키지 부모 디렉토리 — 미설정 시 자동 감지
# SCANNER_PROJECT_ROOT=/app

# Phase D — Claude Sonnet 4.6 narrative 호출용. 미설정 시 narrative 섹션 omit + errors[NO_API_KEY].
ANTHROPIC_API_KEY=sk-ant-...
